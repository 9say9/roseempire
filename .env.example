# Rose Empire — copy to `.env` (never commit .env)

# Stripe Checkout (required for card payments)
# Use test keys locally: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Public site URL used in checkout success/cancel redirects
SITE_URL=https://www.roseempire.co.uk

# Local server bind (optional)
CHAT_HOST=127.0.0.1
CHAT_PORT=5000
