OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# AI Router (start_ai_router.bat) — rotates cloud keys, Ollama fallback
AI_ROUTER_URL=http://127.0.0.1:8000/v1
AI_ROUTER_MODEL=gemini-free
AI_ROUTER_COOLDOWN=30
AI_ROUTER_REQUEST_TIMEOUT=120
LITELLM_ROUTING_STRATEGY=simple-shuffle
OLLAMA_MODELS=qwen2.5-coder:1.5b,qwen2.5-coder:7b,gemma3:4b

# Optional extra free/cheap providers — leave blank if you do not have keys
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
MISTRAL_API_KEY=your_mistral_key_here

# Free local AI — uses whatever you have pulled (1.5b is enough; 7b not required)
AI_PROVIDER=auto
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_TOOLS_MODEL=gemma4:31b-cloud
OLLAMA_FALLBACK_MODELS=qwen2.5-coder:1.5b,qwen2.5-coder:7b

﻿# Rose Empire — copy to `.env` on each PC (NEVER commit .env to GitHub)

GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Business email (Microsoft 365 SMTP) — for Manchester sales pipeline only
INFO_EMAIL=info@roseempire.co.uk
EMAIL_PASSWORD=your_m365_app_password_here

CHAT_PORT=5000
CHAT_HOST=127.0.0.1
FLEET_PORT=5050
FLEET_HOST=127.0.0.1

# Stripe checkout (optional but required for direct payments)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
SITE_URL=https://www.roseempire.co.uk
