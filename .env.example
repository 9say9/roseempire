# Rose Empire — copy to `.env` on each PC (NEVER commit .env to GitHub)

# Chat API (local server + Cloudflare Worker secret only — set via wrangler secret put)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional email (local only — never commit real password)
# EMAIL_ADDRESS=your_email@example.com
# EMAIL_PASSWORD=your_app_password_here

CHAT_PORT=5000
CHAT_HOST=127.0.0.1
