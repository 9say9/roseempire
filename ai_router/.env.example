# AI Router — copy to ai_router/.env OR use repo root .env

# Unified model name clients send (OpenAI-compatible). Aliases: gemini-free, gpt-3.5-turbo
AI_ROUTER_MODEL=gpt-3.5-turbo
AI_ROUTER_HOST=0.0.0.0
AI_ROUTER_PORT=8000
AI_ROUTER_COOLDOWN=60

# Gemini (router rotates multiple keys; falls back if 429)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional cloud providers (skipped if blank)
GROQ_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# Ollama 1.5b cannot do native Roo tool calls — skip when tools are present
AI_ROUTER_SKIP_OLLAMA_FOR_TOOLS=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
